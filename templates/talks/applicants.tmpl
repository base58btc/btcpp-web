<!DOCTYPE html>
<html>
  <head>
    <title>speaker applicants @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
    {{ template "admin_favicon" .Conf }}
  </head>
  <body>
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-5xl">
            <a href="/{{ .Conf.Tag }}/admin" class="text-xs text-gray-500 hover:text-gray-700">&larr; {{ .Conf.Desc }} dashboard</a>
            <section id="topline" class="mt-2 mb-6">
                <div class="overflow-hidden sm:rounded-lg bg-white shadow">
                    <div class="px-4 py-5 sm:p-6 flex items-center justify-between gap-4">
                        <div>
                            <h1 class="text-xl font-bold text-gray-900">Speaker Applicants</h1>
                            <p class="text-sm text-gray-500">{{ .Conf.Desc }} - {{ .Conf.DateDesc }}</p>
                        </div>
                        <div class="flex items-center gap-2 shrink-0">
                            <a href="/{{ .Conf.Tag }}/admin/invite-speaker"
                               class="inline-flex items-center rounded-md bg-green-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-green-700">
                                Invite a speaker
                            </a>
                            <form method="POST" action="/{{ .Conf.Tag }}/admin/applicants/resend-tickets">
                                <button type="submit"
                                        onclick="return confirm('Issue speaker tickets for every Accepted proposal whose speakers don't already have a ticket for this conf?');"
                                        class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-indigo-700">
                                    Resend tickets
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </section>

            {{ if .FlashMessage }}
            <section class="mb-6">
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg">
                    {{ .FlashMessage }}
                </div>
            </section>
            {{ end }}

            {{ if .Rows }}
            <form method="POST" action="/{{ .Conf.Tag }}/admin/applicants/email">
            <section id="applicants-table" class="mb-6">
                <div class="bg-white shadow rounded-lg overflow-hidden">
                    <table class="min-w-full sm:divide-y sm:divide-gray-200">
                        <thead class="bg-gray-50 hidden sm:table-header-group">
                            <tr>
                                <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-10">
                                    <input type="checkbox" onclick="toggleAll(this)" class="rounded border-gray-300">
                                </th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Talk</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white sm:divide-y sm:divide-gray-200">
                            {{ range .Rows }}
                            <tr class="hover:bg-gray-50 block sm:table-row border-b sm:border-0 border-gray-200 px-4 py-4 sm:p-0">
                                <td class="block sm:table-cell sm:px-3 sm:py-4 pb-2 sm:pb-4">
                                    <label class="inline-flex items-center gap-2 sm:gap-0">
                                        <input type="checkbox" name="proposal_refs" value="{{ .Proposal.ID }}" class="app-checkbox rounded border-gray-300">
                                        <span class="text-xs uppercase text-gray-500 sm:hidden">Select</span>
                                    </label>
                                </td>
                                <td class="block sm:table-cell sm:px-6 sm:py-4 text-sm text-gray-900">
                                    <span class="text-xs uppercase text-gray-500 sm:hidden mr-1">Name:</span>{{ if .Speaker }}{{ .Speaker.Name }}{{ end }}
                                </td>
                                <td class="block sm:table-cell sm:px-6 sm:py-4 text-sm text-gray-900 break-all">
                                    <span class="text-xs uppercase text-gray-500 sm:hidden mr-1">Email:</span>{{ if .Speaker }}{{ .Speaker.Email }}{{ end }}
                                </td>
                                <td class="block sm:table-cell sm:px-6 sm:py-4 text-sm text-gray-500">
                                    <span class="text-xs uppercase text-gray-500 sm:hidden mr-1">Talk:</span>{{ .Proposal.Title }}
                                </td>
                                <td class="block sm:table-cell sm:px-6 sm:py-4 text-sm text-gray-500">
                                    <span class="text-xs uppercase text-gray-500 sm:hidden mr-1">Status:</span>{{ .Proposal.Status }}
                                </td>
                                <td class="block sm:table-cell sm:px-6 sm:py-4 sm:text-right pt-2 sm:pt-4">
                                    {{ $invite := inviteLink .Proposal }}
                                    {{ $terminal := or (eq .Proposal.Status "Accepted") (eq .Proposal.Status "TheyDecline") (eq .Proposal.Status "WeDecline") (eq .Proposal.Status "Rejected") }}
                                    <span class="flex flex-wrap items-center gap-2 sm:justify-end">
                                        {{ if $invite }}
                                        <button type="button"
                                                data-invite-url="{{ $invite }}"
                                                class="copy-invite-btn inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-indigo-700">
                                            Copy invite
                                        </button>
                                        {{ end }}
                                        {{ if $terminal }}
                                        {{ if eq .Proposal.Status "Accepted" }}
                                        <button type="submit"
                                            formaction="/{{ $.Conf.Tag }}/admin/applicants/{{ .Proposal.ID }}/cancel"
                                            formmethod="POST"
                                            onclick="return confirm('Cancel this talk? Status will be set to TheyDecline. This is for the case where the speaker pulls out after confirming.');"
                                            class="inline-flex items-center rounded-md bg-red-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-red-700">
                                            Cancel
                                        </button>
                                        {{ else }}{{ if not $invite }}
                                        <span class="text-xs text-gray-400">—</span>
                                        {{ end }}{{ end }}
                                        {{ else }}
                                        {{ if ne .Proposal.Status "Invited" }}
                                        <button type="submit"
                                            formaction="/{{ $.Conf.Tag }}/admin/review/{{ .Proposal.ID }}/invite?return=%2F{{ $.Conf.Tag }}%2Fadmin%2Fapplicants"
                                            formmethod="POST"
                                            class="inline-flex items-center rounded-md bg-green-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-green-700">
                                            Invite
                                        </button>
                                        {{ end }}
                                        {{ if and (ne .Proposal.Status "Waitlisted") (ne .Proposal.Status "Invited") }}
                                        <button type="submit"
                                            formaction="/{{ $.Conf.Tag }}/admin/review/{{ .Proposal.ID }}/waitlist?return=%2F{{ $.Conf.Tag }}%2Fadmin%2Fapplicants"
                                            formmethod="POST"
                                            class="inline-flex items-center rounded-md bg-yellow-500 px-3 py-1.5 text-xs font-semibold text-white hover:bg-yellow-600">
                                            Waitlist
                                        </button>
                                        {{ end }}
                                        <button type="submit"
                                            formaction="/{{ $.Conf.Tag }}/admin/review/{{ .Proposal.ID }}/decline?return=%2F{{ $.Conf.Tag }}%2Fadmin%2Fapplicants"
                                            formmethod="POST"
                                            class="inline-flex items-center rounded-md bg-gray-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-gray-700">
                                            Decline
                                        </button>
                                        <button type="submit"
                                            formaction="/{{ $.Conf.Tag }}/admin/review/{{ .Proposal.ID }}/confirm?return=%2F{{ $.Conf.Tag }}%2Fadmin%2Fapplicants"
                                            formmethod="POST"
                                            class="text-xs text-gray-500 hover:text-gray-800 underline bg-transparent border-0 p-0">
                                            Mark Confirmed
                                        </button>
                                        {{ end }}
                                    </span>
                                </td>
                            </tr>
                            {{ end }}
                        </tbody>
                    </table>
                    <div class="px-6 py-3 bg-gray-50 text-sm text-gray-500">
                        {{ len .Rows }} applicants
                    </div>
                </div>
            </section>

            {{ template "email_compose" .EmailCompose }}
            </form>
            {{ else }}
            <section class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-5 sm:p-6 text-center text-gray-500">
                    No applicants found for this event.
                </div>
            </section>
            {{ end }}
        </div>
    </div>
    <script>
    function toggleAll(source) {
        var checkboxes = document.querySelectorAll('.app-checkbox');
        checkboxes.forEach(function(cb) { cb.checked = source.checked; });
    }
    // Per-row Copy invite buttons. data-invite-url carries the speaker's
    // pre-built magic link so we don't string-build at click time;
    // server-rendered to keep the template in charge of URL shape.
    (function () {
      document.querySelectorAll('.copy-invite-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var url = btn.dataset.inviteUrl;
          if (!url) return;
          var original = btn.textContent;
          navigator.clipboard.writeText(url).then(function () {
            btn.textContent = 'Copied!';
            btn.classList.add('bg-green-600');
            btn.classList.remove('bg-indigo-600', 'hover:bg-indigo-700');
            setTimeout(function () {
              btn.textContent = original;
              btn.classList.remove('bg-green-600');
              btn.classList.add('bg-indigo-600', 'hover:bg-indigo-700');
            }, 1500);
          }).catch(function () {
            btn.textContent = 'Copy failed';
            setTimeout(function () { btn.textContent = original; }, 1500);
          });
        });
      });
    })();
    </script>
  </body>
</html>

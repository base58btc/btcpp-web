<!DOCTYPE html>
<html>
  <head>
    <title>speaker admin @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#127908;</text></svg>">
  </head>
  <body>
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-5xl">
            <section id="topline" class="mb-6">
                <div class="overflow-hidden sm:rounded-lg bg-white shadow">
                    <div class="px-4 py-5 sm:p-6">
                        <h1 class="text-xl font-bold text-gray-900">Speaker Admin</h1>
                        <p class="text-sm text-gray-500">{{ .Conf.Desc }} - {{ .Conf.DateDesc }}</p>
                    </div>
                </div>
            </section>

            {{ if .FlashMessage }}
            <section class="mb-6">
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg">
                    {{ .FlashMessage }}
                </div>
            </section>
            {{ end }}

            <section id="controls" class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-4 sm:px-6">
                    <div class="flex items-center gap-2">
                        {{ if .Rows }}
                        <button type="button" onclick="downloadCSV()" class="px-3 py-1.5 text-sm rounded-md text-white bg-green-600 hover:bg-green-700">Download CSV</button>
                        <a href="#compose" class="px-3 py-1.5 text-sm rounded-md text-white bg-indigo-600 hover:bg-indigo-700">Email Selected</a>
                        {{ end }}
                        <form method="POST" action="/admin/speakers/{{ .Conf.Tag }}/sendcal">
                            <button type="submit" class="px-3 py-1.5 text-sm rounded-md text-white bg-orange-600 hover:bg-orange-700" onclick="return confirm('Send calendar invites to all speakers for {{ .Conf.Desc }}?')">Send Speaker Calendar Invites</button>
                        </form>
                    </div>
                </div>
            </section>

            {{ if .Rows }}
            <form id="speaker-email-form" method="POST" action="/admin/speakers/{{ .Conf.Tag }}/email">
            <section id="speakers-table" class="mb-6">
                <div class="bg-white shadow rounded-lg overflow-hidden">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-10">
                                    <input type="checkbox" onclick="toggleAllSpeakers(this)" class="rounded border-gray-300">
                                </th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Signal</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            {{ range .Rows }}
                            <tr class="hover:bg-gray-50">
                                <td class="px-3 py-4">
                                    <input type="checkbox" name="speaker_refs" value="{{ .ID }}" class="speaker-checkbox rounded border-gray-300">
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-900">{{ .Name }}</td>
                                <td class="px-6 py-4 text-sm text-gray-900">{{ .Email }}</td>
                                <td class="px-6 py-4 text-sm text-gray-900">{{ .Signal }}</td>
                            </tr>
                            {{ end }}
                        </tbody>
                    </table>
                    <div class="px-6 py-3 bg-gray-50 text-sm text-gray-500">
                        {{ len .Rows }} speakers
                    </div>
                </div>
            </section>

            <!-- Compose Email -->
            <section id="compose" class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-4 sm:px-6">
                    <h3 class="text-sm font-semibold text-gray-900 mb-3">Email Selected Speakers</h3>
                    <p class="text-xs text-gray-500 mb-3">Write a one-off email to speakers. The body and title can use Go template syntax with <code class="bg-gray-100 px-1">.Speaker</code>, <code class="bg-gray-100 px-1">.Conf</code>, and <code class="bg-gray-100 px-1">.Talks</code>.</p>

                    <details class="mb-3 text-xs text-gray-500">
                        <summary class="cursor-pointer font-medium text-gray-700 hover:text-gray-900">Available template fields</summary>
                        <div class="mt-2 grid grid-cols-1 sm:grid-cols-3 gap-4 p-3 bg-gray-50 rounded">
                            <div>
                                <h4 class="font-semibold text-gray-700 mb-1">.Speaker</h4>
                                <ul class="space-y-0.5">
                                    {{ range .SpeakerFields }}<li><code>.Speaker.{{ . }}</code></li>
                                    {{ end }}
                                </ul>
                            </div>
                            <div>
                                <h4 class="font-semibold text-gray-700 mb-1">.Conf</h4>
                                <ul class="space-y-0.5">
                                    {{ range .ConfFields }}<li><code>.Conf.{{ . }}</code></li>
                                    {{ end }}
                                </ul>
                            </div>
                            <div>
                                <h4 class="font-semibold text-gray-700 mb-1">.Talks (range)</h4>
                                <p class="mb-1"><code>{{`{{ range .Talks }}`}}</code></p>
                                <ul class="space-y-0.5">
                                    {{ range .TalkFields }}<li><code>.{{ . }}</code></li>
                                    {{ end }}
                                </ul>
                                <p class="mt-1"><code>{{`{{ end }}`}}</code></p>
                            </div>
                        </div>
                    </details>

                    <label class="block text-xs font-medium text-gray-700 mb-1">Title</label>
                    <input type="text" name="title" class="w-full rounded border border-gray-300 px-3 py-1.5 text-sm mb-3" placeholder="Subject line">
                    <label class="block text-xs font-medium text-gray-700 mb-1">Body (Markdown)</label>
                    <textarea name="body" rows="10" class="w-full rounded border border-gray-300 px-3 py-1.5 text-sm font-mono" placeholder="Hi {{`{{ .Speaker.Name }}`}},&#10;&#10;Looking forward to your talk at {{`{{ .Conf.Desc }}`}}..."></textarea>

                    <button type="submit" class="mt-3 inline-flex items-center px-4 py-2 text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700"
                            onclick="return confirm('Send email to selected speakers?')">
                        Send Email
                    </button>
                </div>
            </section>
            </form>
            {{ else }}
            <section class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-5 sm:p-6 text-center text-gray-500">
                    No speakers found for this event.
                </div>
            </section>
            {{ end }}
        </div>
    </div>
    {{ if .Rows }}
    <script>
    function downloadCSV() {
        var rows = document.querySelectorAll('#speakers-table tbody tr');
        var csv = 'Name,Email\n';
        rows.forEach(function(row) {
            var cells = row.querySelectorAll('td');
            var name = '"' + cells[1].textContent.trim().replace(/"/g, '""') + '"';
            var email = '"' + cells[2].textContent.trim().replace(/"/g, '""') + '"';
            csv += name + ',' + email + '\n';
        });
        var blob = new Blob([csv], {type: 'text/csv'});
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = '{{ .Conf.Tag }}_speakers.csv';
        a.click();
    }
    function toggleAllSpeakers(source) {
        var checkboxes = document.querySelectorAll('.speaker-checkbox');
        checkboxes.forEach(function(cb) { cb.checked = source.checked; });
    }
    </script>
    {{ end }}
  </body>
</html>

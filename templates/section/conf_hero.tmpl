{{/*
  conf_hero — standalone hero card showing a conf's leading.avif with
  emoji + name + date overlay, anchor to the public conf page. Used at
  the top of the dashboard subpages (edit talk / edit speaker info /
  invite-link) for visual continuity with the per-event blocks on the
  main dashboard.

  Receives a *types.Conf.

  The hero on the main dashboard is inline inside a per-event card so
  it can share the card's outer overflow-hidden + rounded-lg; this
  variant is self-contained for use as a standalone element.
*/}}
{{ define "conf_hero" }}
{{ $conf := . }}
<a href="/{{ $conf.Tag }}" class="block relative h-36 sm:h-40 group bg-gray-200 rounded-lg overflow-hidden shadow">
  <picture>
    <source srcset="/static/img/{{ $conf.Tag }}/leading.avif" type="image/avif" />
    <img src="/static/img/{{ $conf.Tag }}/leading.png" alt="{{ $conf.Desc }}"
         class="absolute inset-0 w-full h-full object-cover" />
  </picture>
  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 px-4 sm:px-6 pb-4 flex items-end justify-between gap-3 text-white">
    <div class="min-w-0">
      <div class="flex items-center gap-2">
        <span class="text-xl">{{ $conf.EmojiOrDefault }}</span>
        <h2 class="text-lg sm:text-xl font-bold truncate">{{ $conf.Desc }}</h2>
      </div>
      <p class="mt-0.5 text-xs sm:text-sm opacity-90">{{ $conf.DateDesc }} · {{ $conf.Location }}</p>
    </div>
    <span class="shrink-0 text-xs opacity-80 group-hover:opacity-100 hidden sm:inline">View conf &rarr;</span>
  </div>
</a>
{{ end }}

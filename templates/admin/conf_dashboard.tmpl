<!DOCTYPE html>
<html>
<head>
  <title>{{ .Conf.Desc }} · organizer dashboard</title>
  {{ block "header" . }} {{ end }}
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🧜‍♂️</text></svg>">
</head>
<body class="bg-gray-50">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center gap-4">
      <div class="text-3xl">{{ .Conf.EmojiOrDefault }}</div>
      <div>
        <h1 class="text-2xl font-bold text-gray-900">{{ .Conf.Desc }}</h1>
        <p class="text-sm text-gray-500">{{ .Conf.DateDesc }} - {{ .Conf.Location }}</p>
      </div>
    </div>

    {{ if .FlashMessage }}
    <div class="mt-6 rounded-md bg-green-50 border border-green-200 px-4 py-3">
      <p class="text-sm text-green-800">{{ .FlashMessage }}</p>
    </div>
    {{ end }}

    <h2 class="mt-10 text-xs font-semibold uppercase tracking-wider text-gray-500">Talk applications</h2>
    <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-3">
      <a href="/{{ .Conf.Tag }}/admin/review"
         class="group flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-indigo-50 hover:shadow-md transition">
        <div class="text-2xl">&#128221;</div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-semibold text-gray-900">Review applications</p>
          <p class="text-xs text-gray-500">
            {{ if .PendingCount }}{{ .PendingCount }} pending{{ else }}all caught up{{ end }}{{ if .DecisionedCount }} &middot; {{ .DecisionedCount }} decisioned{{ end }}
          </p>
        </div>
        <span class="text-sm font-medium text-indigo-600 group-hover:text-indigo-700">Walk through &rarr;</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/applicants"
         class="group flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50 hover:shadow-md transition">
        <div class="text-2xl">&#128203;</div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-semibold text-gray-900">Applicant list</p>
          <p class="text-xs text-gray-500">Bulk view + custom email</p>
        </div>
        <span class="text-sm font-medium text-gray-600 group-hover:text-gray-900">Open &rarr;</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/schedule"
         class="group flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-indigo-50 hover:shadow-md transition">
        <div class="text-2xl">&#128197;</div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-semibold text-gray-900">Schedule talks</p>
          <p class="text-xs text-gray-500">Drag &amp; drop into venues</p>
        </div>
        <span class="text-sm font-medium text-indigo-600 group-hover:text-indigo-700">Open &rarr;</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/invite-speaker"
         class="group flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-indigo-50 hover:shadow-md transition">
        <div class="text-2xl">&#128231;</div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-semibold text-gray-900">Invite a speaker</p>
          <p class="text-xs text-gray-500">Send a magic link directly</p>
        </div>
        <span class="text-sm font-medium text-indigo-600 group-hover:text-indigo-700">Open &rarr;</span>
      </a>
    </div>

    <h2 class="mt-10 text-xs font-semibold uppercase tracking-wider text-gray-500">Other event tools</h2>
    <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-3">
      <a href="/{{ .Conf.Tag }}/admin/speakers"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#127908;</div>
        <span class="text-sm font-medium text-gray-900">Speakers</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/registrations"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#127915;</div>
        <span class="text-sm font-medium text-gray-900">Registrations</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/sponsors"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#128176;</div>
        <span class="text-sm font-medium text-gray-900">Sponsorships</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/social"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#128241;</div>
        <span class="text-sm font-medium text-gray-900">Social posts</span>
      </a>
      <a href="/{{ .Conf.Tag }}/volcoord"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#129489;</div>
        <span class="text-sm font-medium text-gray-900">Volunteers</span>
      </a>
    </div>
  </div>
  {{ block "footer" . }} {{ end }}
</body>
</html>

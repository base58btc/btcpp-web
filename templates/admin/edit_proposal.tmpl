<!DOCTYPE html>
<html>
<head>
  <title>Edit talk - {{ .Conf.Desc }}</title>
  {{ block "header" . }} {{ end }}
  {{ template "admin_favicon" .Conf }}
</head>
<body class="bg-gray-50">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-4">
      <a href="{{ .ReturnURL }}" class="text-xs text-gray-500 hover:text-gray-700">&larr; back</a>
    </div>

    <section class="mb-6">
      <div class="overflow-hidden sm:rounded-lg bg-white shadow">
        <div class="px-4 py-5 sm:p-6">
          <h1 class="text-xl font-bold text-gray-900">Edit talk</h1>
          <p class="mt-1 text-sm text-gray-500">{{ .Conf.Desc }} &middot; {{ .Conf.DateDesc }}</p>
          <p class="mt-2 text-xs text-gray-500">
            Status: <span class="font-medium text-gray-700">{{ .Proposal.Status }}</span>.
            Changes write to Notion immediately. If this talk is already <em>Scheduled</em>,
            attendees won't see updated cal-invite copy until you trigger
            <span class="font-mono">Send cal updates</span> from the schedule page.
          </p>
        </div>
      </div>
    </section>

    {{ if .Flash }}
    <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3">
      <p class="text-sm text-green-800">{{ .Flash }}</p>
    </div>
    {{ end }}
    {{ if .FlashErr }}
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3">
      <p class="text-sm text-red-800">{{ .FlashErr }}</p>
    </div>
    {{ end }}

    <form method="POST" action="/{{ .Conf.Tag }}/admin/proposal/{{ .Proposal.ID }}/edit?return={{ .ReturnURL }}"
          class="space-y-6 bg-white shadow rounded-lg p-6">

      <div>
        <label for="Title" class="block text-sm font-semibold text-gray-900">Title</label>
        <input id="Title" name="Title" type="text" required
               value="{{ .Proposal.Title }}"
               class="mt-1 block w-full rounded-md border-gray-300 shadow-sm py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:outline-bitcoin" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="TalkType" class="block text-sm font-semibold text-gray-900">Type</label>
          <select id="TalkType" name="TalkType" required
                  class="mt-1 block w-full rounded-md py-2 pl-3 pr-7 outline outline-1 -outline-offset-1 outline-gray-300">
            {{ $current := .Proposal.TalkType }}
            {{ range .TalkTypes }}
            <option value="{{ . }}" {{ if eq . $current }}selected{{ end }}>{{ . }}</option>
            {{ end }}
          </select>
        </div>
        <div>
          <label for="DesiredDuration" class="block text-sm font-semibold text-gray-900">Duration (min)</label>
          <select id="DesiredDuration" name="DesiredDuration" required
                  class="mt-1 block w-full rounded-md py-2 pl-3 pr-7 outline outline-1 -outline-offset-1 outline-gray-300">
            {{ $cur := .Proposal.DesiredDuration }}
            {{ range .Durations }}
            <option value="{{ . }}" {{ if eq . $cur }}selected{{ end }}>{{ . }}</option>
            {{ end }}
          </select>
        </div>
      </div>

      <div>
        <label for="Description" class="block text-sm font-semibold text-gray-900">Description</label>
        <textarea id="Description" name="Description" rows="6" required
                  class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300">{{ .Proposal.Description }}</textarea>
      </div>

      <div>
        <label for="Setup" class="block text-sm font-semibold text-gray-900">Setup / equipment</label>
        <textarea id="Setup" name="Setup" rows="3"
                  class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300">{{ .Proposal.Setup }}</textarea>
      </div>

      <div>
        <label for="Comments" class="block text-sm font-semibold text-gray-900">Comments</label>
        <textarea id="Comments" name="Comments" rows="3"
                  class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300">{{ .Proposal.Comments }}</textarea>
      </div>

      <div class="flex items-center justify-end gap-3 pt-2">
        <a href="{{ .ReturnURL }}"
           class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900">Cancel</a>
        <button type="submit"
                class="px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
          Save changes
        </button>
      </div>
    </form>
  </div>
</body>
</html>

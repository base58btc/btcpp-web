<!DOCTYPE html>
<html>
  <head>
    <title>{{ if .Row.ConfTalk }}{{ if .Row.ConfTalk.Proposal }}{{ .Row.ConfTalk.Proposal.Title }}{{ else }}{{ .Row.Recording.TalkName }}{{ end }}{{ else }}{{ .Row.Recording.TalkName }}{{ end }} · recording</title>
    {{ block "header" . }} {{ end }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#127909;</text></svg>">
  </head>
  <body>
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-8">

      <a href="/admin/recordings" class="text-xs text-gray-500 hover:text-gray-700">&larr; back to recordings</a>

      <header class="mt-2 mb-6">
        <h1 class="text-2xl font-bold text-gray-900">
          {{ if .Row.ConfTalk }}{{ if .Row.ConfTalk.Proposal }}{{ .Row.ConfTalk.Proposal.Title }}{{ else }}{{ .Row.Recording.TalkName }}{{ end }}{{ else }}{{ .Row.Recording.TalkName }}{{ end }}
        </h1>
        <p class="text-sm text-gray-500 mt-1">
          {{ if and .Row.ConfTalk .Row.ConfTalk.Conf }}<span>{{ .Row.ConfTalk.Conf.Desc }}</span>{{ end }}
          {{ if and .Row.ConfTalk .Row.ConfTalk.Sched }}<span class="ml-2">· recorded {{ .Row.ConfTalk.Sched.Start.Format "Jan 2, 2006" }}</span>{{ end }}
        </p>
        {{ if .Row.Speakers }}
        <p class="text-sm text-gray-700 mt-1">
          Speakers:
          {{ range $i, $s := .Row.Speakers }}{{ if $i }}, {{ end }}{{ $s.Name }}{{ if $s.Twitter.Handle }} (<a href="{{ $s.Twitter.Link }}" class="text-indigo-600" target="_blank" rel="noopener">@{{ $s.Twitter.Handle }}</a>){{ end }}{{ end }}
        </p>
        {{ end }}
      </header>

      {{ if .FlashMessage }}
      <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">{{ .FlashMessage }}</div>
      {{ end }}
      {{ if .FlashError }}
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">{{ .FlashError }}</div>
      {{ end }}

      <section class="mb-6 bg-white shadow rounded-lg p-5">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500 mb-3">Source video</h2>
        {{ if .Row.Recording.FileURI }}
        <p class="text-sm text-gray-700">Spaces key: <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs">{{ .Row.Recording.FileURI }}</code></p>
        {{ else }}
        <p class="text-sm text-yellow-700">No <code>FileURI</code> set. Add the Spaces key to the Notion Recording row before uploading.</p>
        {{ end }}
      </section>

      <!-- YouTube section -->
      <section class="mb-6 bg-white shadow rounded-lg p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500">YouTube</h2>
          {{ if .Row.Recording.YTLink }}
          <a href="{{ .Row.Recording.YTLink }}" target="_blank" rel="noopener" class="text-xs text-indigo-600 hover:text-indigo-800">{{ .Row.Recording.YTLink }} ↗</a>
          {{ end }}
        </div>

        {{ if .JobActive }}
        <div id="yt-status" class="mb-4 rounded-md bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-800">
          Uploading to YouTube… this can take several minutes for a longform talk. You can leave this page; the upload continues server-side.
        </div>
        <script>
          (function poll() {
            fetch('/admin/recordings/{{ .Row.Recording.ID }}/status')
              .then(r => r.json())
              .then(j => {
                if (j.status === 'succeeded') {
                  location.reload();
                } else if (j.status === 'failed') {
                  document.getElementById('yt-status').className = 'mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800';
                  document.getElementById('yt-status').innerText = 'Upload failed: ' + j.message;
                } else {
                  setTimeout(poll, 4000);
                }
              })
              .catch(() => setTimeout(poll, 6000));
          })();
        </script>
        {{ else if eq .JobStatus "failed" }}
        <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">Last upload failed: {{ .JobMessage }}</div>
        {{ else if eq .JobStatus "succeeded" }}
        <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">Upload succeeded: <a href="{{ .JobMessage }}" target="_blank" rel="noopener" class="underline">{{ .JobMessage }}</a></div>
        {{ end }}

        <form method="POST" action="/admin/recordings/{{ .Row.Recording.ID }}/upload-yt" class="space-y-4">
          <div>
            <label class="block text-xs font-medium text-gray-700">Title <span class="text-gray-400">(max 100 chars)</span></label>
            <input type="text" name="yt_title" value="{{ .YTTitle }}" maxlength="100"
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-bitcoin">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-700">Description</label>
            <textarea name="yt_body" rows="14"
                      class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-bitcoin font-mono">{{ .YTBody }}</textarea>
          </div>
          <div class="flex items-center gap-3">
            <label class="text-xs text-gray-700">
              Privacy:
              <select name="privacy" class="ml-1 rounded border-gray-300 text-sm">
                <option value="public" selected>Public</option>
                <option value="unlisted">Unlisted</option>
                <option value="private">Private</option>
              </select>
            </label>
            <button type="submit"
                    {{ if or (not .YouTubeReady) (not .Row.Recording.FileURI) .JobActive }}disabled{{ end }}
                    class="px-4 py-2 text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 disabled:bg-gray-300 disabled:cursor-not-allowed">
              {{ if .Row.Recording.YTLink }}Re-upload to YouTube{{ else }}Upload to YouTube{{ end }}
            </button>
            {{ if not .YouTubeReady }}
            <span class="text-xs text-gray-500">(authorize YouTube on the recordings page first)</span>
            {{ else if not .Row.Recording.FileURI }}
            <span class="text-xs text-gray-500">(no FileURI set in Notion)</span>
            {{ end }}
          </div>
        </form>
      </section>

      <!-- X section (manual handoff for now) -->
      <section class="mb-6 bg-white shadow rounded-lg p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500">X.com</h2>
          {{ if .Row.Recording.XLink }}
          <a href="{{ .Row.Recording.XLink }}" target="_blank" rel="noopener" class="text-xs text-indigo-600 hover:text-indigo-800">{{ .Row.Recording.XLink }} ↗</a>
          {{ end }}
        </div>

        <p class="text-xs text-gray-500 mb-3">No X developer plan yet, so this is a two-step handoff: copy the text below, click <strong>Open X compose</strong>, attach the video manually, post, then paste the resulting URL back here.</p>

        <div class="space-y-3">
          <textarea id="x-body" rows="6" readonly
                    class="block w-full rounded-md bg-gray-50 px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 font-mono">{{ .XBody }}</textarea>
          <div class="flex items-center gap-3">
            <button type="button" onclick="navigator.clipboard.writeText(document.getElementById('x-body').value); this.innerText='Copied!'; setTimeout(()=>this.innerText='Copy text',1500);"
                    class="px-3 py-1.5 text-sm rounded-md bg-gray-100 text-gray-700 hover:bg-gray-200">Copy text</button>
            <a href="{{ .XIntentURL }}" target="_blank" rel="noopener"
               class="px-3 py-1.5 text-sm rounded-md text-white bg-black hover:bg-gray-800">Open X compose ↗</a>
          </div>
        </div>

        <form method="POST" action="/admin/recordings/{{ .Row.Recording.ID }}/x" class="mt-5 space-y-2">
          <label class="block text-xs font-medium text-gray-700">Resulting X URL</label>
          <div class="flex gap-2">
            <input type="text" name="x_url" value="{{ .Row.Recording.XLink }}" placeholder="https://x.com/btcplusplus/status/…"
                   class="flex-1 rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-bitcoin">
            <button type="submit" class="px-3 py-1.5 text-sm rounded-md text-white bg-indigo-600 hover:bg-indigo-700">Save</button>
          </div>
        </form>
      </section>

    </div>
  </body>
</html>

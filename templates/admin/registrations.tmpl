<!DOCTYPE html>
<html>
  <head>
    <title>registrations @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#127915;</text></svg>">
  </head>
  <body>
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-5xl">
            <section id="topline" class="mb-6">
                <div class="overflow-hidden sm:rounded-lg bg-white shadow">
                    <div class="px-4 py-5 sm:p-6">
                        <h1 class="text-xl font-bold text-gray-900">Registrations</h1>
                        <p class="text-sm text-gray-500">{{ .Conf.Desc }} - {{ .Conf.DateDesc }}</p>
                        <p class="mt-1 text-xs text-gray-400">{{ len .Registrations }} unique attendees</p>
                    </div>
                </div>
            </section>

            {{ if .FlashMessage }}
            <section class="mb-6">
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg">
                    {{ .FlashMessage }}
                </div>
            </section>
            {{ end }}

            {{ if .Registrations }}
            <section class="mb-4">
                <div class="bg-white shadow rounded-lg px-4 py-3 sm:px-6">
                    <input type="text" id="search-input" placeholder="Search by email, type, or ticket..."
                        class="w-full rounded border border-gray-300 px-3 py-1.5 text-sm"
                        oninput="filterTable()">
                </div>
            </section>

            <form method="POST" action="/admin/registrations/{{ .Conf.Tag }}/email">
            <section id="registrations-table" class="mb-6">
                <div class="bg-white shadow rounded-lg overflow-hidden">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-10">
                                    <input type="checkbox" onclick="toggleAll(this)" class="rounded border-gray-300">
                                </th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ticket</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            {{ range .Registrations }}
                            <tr class="hover:bg-gray-50">
                                <td class="px-3 py-4">
                                    <input type="checkbox" name="reg_emails" value="{{ .Email }}" class="reg-checkbox rounded border-gray-300">
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-900">{{ .Email }}</td>
                                <td class="px-6 py-4 text-sm text-gray-500">{{ .Type }}</td>
                                <td class="px-6 py-4 text-sm text-gray-500">{{ .ItemBought }}</td>
                            </tr>
                            {{ end }}
                        </tbody>
                    </table>
                    <div class="px-6 py-3 bg-gray-50 text-sm text-gray-500">
                        {{ len .Registrations }} attendees
                    </div>
                </div>
            </section>

            {{ template "email_compose" .EmailCompose }}
            </form>
            {{ else }}
            <section class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-5 sm:p-6 text-center text-gray-500">
                    No registrations found for this event.
                </div>
            </section>
            {{ end }}
        </div>
    </div>
    <script>
    function toggleAll(source) {
        var checkboxes = document.querySelectorAll('.reg-checkbox');
        checkboxes.forEach(function(cb) {
            var row = cb.closest('tr');
            if (row.style.display !== 'none') {
                cb.checked = source.checked;
            }
        });
    }
    function filterTable() {
        var query = document.getElementById('search-input').value.toLowerCase();
        var rows = document.querySelectorAll('#registrations-table tbody tr');
        rows.forEach(function(row) {
            var text = row.textContent.toLowerCase();
            row.style.display = text.includes(query) ? '' : 'none';
        });
    }
    </script>
  </body>
</html>

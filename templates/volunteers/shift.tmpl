<!DOCTYPE html>
<html>
  <head>
    <title>volunteer @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>✨</text></svg>">
  </head>
  <body>
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl">
            <section id="topline">
                <div class="overflow-hidden sm:rounded-lg bg-white shadow">
                    <div class="px-4 py-5 sm:p-6">
                        <h2 id="profile-overview-title" class="sr-only">Volunteer Shift Overview</h2>
                        <div class="bg-white p-6">
                            <div class="sm:flex sm:items-center sm:justify-between">
                                <div class="sm:flex sm:space-x-5">
                                    <div class="shrink-0">
                                        <img src="https://images.unsplash.com/photo-1550525811-e5869dd03032?ixlib=rb-1.2.1&ixid=eyJhcHBfaWQiOjEyMDd9&auto=format&fit=facearea&facepad=2&w=256&h=256&q=80" alt="" class="mx-auto size-20 rounded-full" />
                                    </div>
                                    <div class="mt-4 text-center sm:mt-0 sm:pt-1 sm:text-left">
                                        <p class="text-sm font-medium text-gray-600">Welcome back,</p>
                                        <p class="text-xl font-bold text-gray-900 sm:text-2xl"> {{ .Name }}</p>
                                        <p class="text-sm font-medium text-gray-600">Traveling from {{ .Hometown }}</p>
                                    </div>
                                </div>
                                <!-- right side button 
                                <div class="mt-5 flex justify-center sm:mt-0">
                                    <a href="#" class="flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50">View profile</a>
                                </div>
                                -->
                            </div>
                        </div>
                        <div class="grid grid-cols-1 divide-y divide-gray-200 border-t border-gray-200 bg-gray-50 sm:grid-cols-3 sm:divide-x sm:divide-y-0">
                            <div class="px-6 py-5 text-center text-sm font-medium">
                                <span class="text-gray-900">{{ .Stats.Applied }}</span>
                                <span class="text-gray-600">Confs Applied for</span>
                            </div>
                            <div class="px-6 py-5 text-center text-sm font-medium">
                                <span class="text-gray-900">{{ .Stats.Pending }}</span>
                                <span class="text-gray-600">Applications Pending</span>
                            </div>
                            <div class="px-6 py-5 text-center text-sm font-medium">
                                <span class="text-gray-900">{{ .Stats.Accepted }}</span>
                                <span class="text-gray-600">Confs Accepted</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <section id="calendar">
            {{ block "vol_shift_card" . }} {{ end }}
            </section>
        </div>
    </div>
    <section id="about">
    {{ block "about" . }} {{ end }}
    </section>
    {{ block "footer" . }} {{ end }}
    <!-- Include this script tag or install `@tailwindplus/elements` via npm: -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindplus/elements@1" type="module"></script>
  </body>
</html>

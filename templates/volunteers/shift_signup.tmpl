<!DOCTYPE html>
<html>
  <head>
    <title>Select Shifts @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>{{ .Conf.Emoji }}</text></svg>">
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
  </head>
  <body>
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-4xl">
            <section id="header" class="py-6">
                <div class="sm:flex sm:items-center sm:justify-between">
                    <div>
                        <h1 class="text-2xl font-bold text-gray-900">Select Your Shifts</h1>
                        <p class="mt-1 text-sm text-gray-600">{{ .Conf.Desc }} - {{ .Conf.DateDesc }}</p>
                    </div>
                    <div class="mt-4 sm:mt-0">
                        <a href="/vols/shift?hr={{ .HMAC }}&em={{ .Email }}" class="text-sm text-indigo-600 hover:text-indigo-500">
                            &larr; Back to Dashboard
                        </a>
                    </div>
                </div>
            </section>

            <div id="shift-list">
                {{ template "shift_list_content" . }}
            </div>
        </div>
    </div>
    {{ block "footer" . }} {{ end }}
  </body>
</html>

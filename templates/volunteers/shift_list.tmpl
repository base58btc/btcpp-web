{{ define "shift_list_content" }}
<!-- Progress Bar -->
<section id="progress" class="mb-6">
    <div class="bg-white shadow rounded-lg p-4">
        <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-medium text-gray-700">Shift Selection Progress</span>
            <span class="text-sm font-medium text-gray-900">{{ .ShiftProgress }}/{{ .MinShifts }} shifts selected</span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2.5">
            {{ if ge .ShiftProgress .MinShifts }}
            <div class="bg-green-600 h-2.5 rounded-full" style="width: 100%"></div>
            {{ else if eq .ShiftProgress 0 }}
            <div class="bg-indigo-600 h-2.5 rounded-full" style="width: 0%"></div>
            {{ else if eq .ShiftProgress 1 }}
            <div class="bg-indigo-600 h-2.5 rounded-full" style="width: 33%"></div>
            {{ else if eq .ShiftProgress 2 }}
            <div class="bg-indigo-600 h-2.5 rounded-full" style="width: 66%"></div>
            {{ else }}
            <div class="bg-indigo-600 h-2.5 rounded-full" style="width: 100%"></div>
            {{ end }}
        </div>
        {{ if .CanSubmit }}
        <p class="mt-2 text-sm text-green-600">You've selected enough shifts! Submit when ready.</p>
        {{ else }}
        <p class="mt-2 text-sm text-gray-500">Please select at least {{ .MinShifts }} shifts to continue.</p>
        {{ end }}
    </div>
</section>

<!-- Submit Button -->
<section id="submit" class="mb-6">
    <div class="flex justify-end">
        {{ if .CanSubmit }}
        <button
            hx-post="/vols/shift/{{ .ConfRef }}/submit?hr={{ .HMAC }}&em={{ .Email }}"
            hx-indicator="#loading-overlay"
            class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
            Submit Shift Selection
        </button>
        {{ else }}
        <button
            disabled
            class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-gray-400 cursor-not-allowed">
            Select {{ sub .MinShifts .ShiftProgress }} More Shifts
        </button>
        {{ end }}
    </div>
</section>

<!-- Selected Shifts Summary -->
{{ if .SelectedShifts }}
<section id="selected" class="mb-6">
    <div class="bg-indigo-50 border border-indigo-200 rounded-lg p-4">
        <h3 class="text-sm font-semibold text-indigo-900 mb-3">Your Selected Shifts</h3>
        <ul class="space-y-2">
            {{ range .SelectedShifts }}
            <li class="flex items-center justify-between text-sm">
                <span class="text-indigo-800">
                    <span class="font-medium">{{ .Name }}</span>
                    <span class="text-indigo-600">- {{ .DayOfDesc }} {{ .TimeDesc }}</span>
                </span>
                {{ if not $.Conf.WithinTwoWeeks }}
                <button
                    hx-post="/vols/shift/{{ $.ConfRef }}/remove?hr={{ $.HMAC }}&em={{ $.Email }}"
                    hx-vals='{"shiftRef":"{{ .Ref }}"}'
                    hx-target="#shift-list"
                    hx-swap="innerHTML"
                    hx-indicator="#loading-overlay"
                    class="text-indigo-600 hover:text-indigo-800 text-xs underline">
                    Remove
                </button>
                {{ end }}
            </li>
            {{ end }}
        </ul>
    </div>
</section>
{{ end }}

<!-- Available Shifts by Day -->
<section id="shifts" class="space-y-6">
    {{ range $day, $shifts := .AvailShifts }}
    <div class="bg-white shadow rounded-lg overflow-hidden">
        <div class="bg-gray-50 px-4 py-3 border-b border-gray-200">
            <h3 class="text-sm font-semibold text-gray-900">
                {{ (index $shifts 0).Shift.DayOfDesc }}
            </h3>
        </div>
        <ul class="divide-y divide-gray-200">
            {{ range $shifts }}
            <li id="shift-{{ .Shift.Ref }}" class="px-4 py-4 {{ if .IsSelected }}bg-indigo-50{{ else if not .CanSelect }}bg-gray-50{{ end }}">
                <div class="flex items-center justify-between">
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center space-x-3">
                            <p class="text-sm font-medium text-gray-900 truncate">{{ .Shift.Name }}</p>
                            {{ if .Shift.Type }}
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
                                {{ .Shift.Type.Title }}
                            </span>
                            {{ end }}
                        </div>
                        {{ if and .Shift.Type .Shift.Type.LongDesc }}
                        <p class="mt-1 text-sm text-gray-600">{{ .Shift.Type.LongDesc }}</p>
                        {{ end }}
                        <div class="mt-1 flex items-center space-x-4 text-sm text-gray-500">
                            <span>{{ .Shift.TimeDesc }}</span>
                            <span>{{ .Shift.SpotsAvailable }} spots left</span>
                        </div>
                        {{ if and (not .CanSelect) (not .IsSelected) }}
                        <p class="mt-1 text-xs text-red-600">{{ .Reason }}</p>
                        {{ end }}
                    </div>
                    <div class="ml-4">
                        {{ if .IsSelected }}
                        {{ if $.Conf.WithinTwoWeeks }}
                        <span class="inline-flex items-center px-3 py-1.5 border border-indigo-300 text-xs font-medium rounded text-indigo-700 bg-indigo-100">
                            Locked In
                        </span>
                        {{ else }}
                        <button
                            hx-post="/vols/shift/{{ $.ConfRef }}/remove?hr={{ $.HMAC }}&em={{ $.Email }}"
                            hx-vals='{"shiftRef":"{{ .Shift.Ref }}"}'
                            hx-target="#shift-list"
                            hx-swap="innerHTML"
                            hx-indicator="#loading-overlay"
                            class="inline-flex items-center px-3 py-1.5 border border-indigo-300 text-xs font-medium rounded text-indigo-700 bg-indigo-100 hover:bg-indigo-200">
                            Selected
                        </button>
                        {{ end }}
                        {{ else if .CanSelect }}
                        <button
                            hx-post="/vols/shift/{{ $.ConfRef }}/select?hr={{ $.HMAC }}&em={{ $.Email }}"
                            hx-vals='{"shiftRef":"{{ .Shift.Ref }}"}'
                            hx-target="#shift-list"
                            hx-swap="innerHTML"
                            hx-indicator="#loading-overlay"
                            class="inline-flex items-center px-3 py-1.5 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50">
                            Select
                        </button>
                        {{ else }}
                        <span class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-gray-400">
                            Unavailable
                        </span>
                        {{ end }}
                    </div>
                </div>
            </li>
            {{ end }}
        </ul>
    </div>
    {{ end }}
</section>
{{ end }}

{{ template "shift_list_content" . }}

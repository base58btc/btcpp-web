<!DOCTYPE html>
<html>
<head>
  <title>your bitcoin++ dashboard</title>
  {{ block "header" . }} {{ end }}
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#10024;</text></svg>">
</head>
<body>
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">

      {{ if .FlashMessage }}
      <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3">
        <p class="text-sm text-green-800">{{ .FlashMessage }}</p>
      </div>
      {{ end }}
      {{ if .FlashError }}
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3">
        <p class="text-sm text-red-800">{{ .FlashError }}</p>
      </div>
      {{ end }}

      <section id="topline">
        <div class="overflow-hidden sm:rounded-lg bg-white shadow">
          <div class="px-4 py-5 sm:p-6">
            <h2 class="sr-only">Dashboard</h2>
            <div class="bg-white p-6">
              <div class="sm:flex sm:items-center sm:justify-between sm:gap-4">
                <div class="sm:flex sm:space-x-5 min-w-0">
                  <div class="shrink-0">
                    {{ if .Photo }}
                    <img src="{{ speakerPhoto .Photo }}" alt="{{ .Name }}"
                         class="mx-auto size-20 rounded-full object-cover bg-gray-50 ring-2 ring-white shadow" />
                    {{ else }}
                    <div class="mx-auto size-20 rounded-full bg-indigo-100 flex items-center justify-center">
                      <span class="text-3xl">&#128075;</span>
                    </div>
                    {{ end }}
                  </div>
                  <div class="mt-4 text-center sm:mt-0 sm:pt-1 sm:text-left min-w-0">
                    <p class="text-sm font-medium text-gray-600">Welcome back,</p>
                    <p class="text-xl font-bold text-gray-900 sm:text-2xl truncate">{{ .Name }}</p>
                    {{ if and .Hometown (ne .Hometown "unknown") }}
                    <p class="text-sm font-medium text-gray-600">From {{ .Hometown }}</p>
                    {{ end }}
                    {{ if .Speaker }}
                    <div class="mt-1 flex flex-wrap justify-center sm:justify-start items-center gap-x-3 gap-y-1 text-xs text-gray-600">
                      {{ if .Speaker.Email }}
                      <a href="mailto:{{ .Speaker.Email }}" class="hover:text-gray-900 truncate">{{ .Speaker.Email }}</a>
                      {{ end }}
                      {{ if .Speaker.Twitter.Handle }}
                      <a href="https://x.com/{{ .Speaker.Twitter.Handle }}" target="_blank" rel="noopener noreferrer" class="hover:text-gray-900">@{{ .Speaker.Twitter.Handle }}</a>
                      {{ end }}
                    </div>
                    {{ end }}
                  </div>
                </div>
                <div class="mt-4 sm:mt-0 flex justify-center sm:justify-end shrink-0 gap-2">
                  {{ if .Speaker }}
                  <a href="/dashboard/speaker?hr={{ .HMAC }}&em={{ .Email }}"
                     class="inline-flex items-center px-3 py-1.5 text-xs font-semibold rounded-md border border-gray-200 text-gray-700 hover:bg-gray-50">
                    Edit profile
                  </a>
                  {{ else }}
                  <a href="/dashboard/speaker?hr={{ .HMAC }}&em={{ .Email }}"
                     class="inline-flex items-center px-3 py-1.5 text-xs font-semibold rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
                    + Create profile
                  </a>
                  {{ end }}
                  <form method="POST" action="/logout" class="inline">
                    <button type="submit"
                            class="inline-flex items-center px-3 py-1.5 text-xs font-semibold rounded-md border border-gray-200 text-gray-500 hover:bg-gray-50 hover:text-gray-700">
                      Sign out
                    </button>
                  </form>
                </div>
              </div>
            </div>
            <div class="grid grid-cols-2 divide-y divide-gray-200 border-t border-gray-200 bg-gray-50 sm:grid-cols-4 sm:divide-x sm:divide-y-0">
              <div class="px-6 py-5 text-center text-sm font-medium">
                <span class="text-gray-900">{{ .Stats.TalksApplied }}</span>
                <span class="text-gray-600">Talks submitted</span>
              </div>
              <div class="px-6 py-5 text-center text-sm font-medium">
                <span class="text-gray-900">{{ .Stats.TalksAccepted }}</span>
                <span class="text-gray-600">Talks accepted</span>
              </div>
              <div class="px-6 py-5 text-center text-sm font-medium">
                <span class="text-gray-900">{{ .Stats.ShiftsApplied }}</span>
                <span class="text-gray-600">Vol. confs</span>
              </div>
              <div class="px-6 py-5 text-center text-sm font-medium">
                <span class="text-gray-900">{{ .Stats.ShiftsBooked }}</span>
                <span class="text-gray-600">Shifts booked</span>
              </div>
            </div>
          </div>
        </div>
      </section>

{{/*
  Per-event blocks: one section per conf the user has any relationship
  with (speaker, volunteer, ticket-holder). All applicable subsections
  render inside the block — talks, vol shift status, tickets, plus
  CTAs to buy more / apply / propose another.
*/}}
{{ if .ActiveBlocks }}
<section id="events" class="mt-8 space-y-6">
  {{ range .ActiveBlocks }}
  {{ $eb := . }}
  {{ $conf := .Conf }}
  <div class="bg-white shadow rounded-lg overflow-hidden">
    {{/* Hero band — uses the conf's leading image with a gradient
         scrim so the title text stays legible on any photo. Anchor
         takes the user to the public conf page. */}}
    <div class="relative">
      <a href="/conf/{{ $conf.Tag }}" class="block relative h-36 sm:h-40 group bg-gray-200">
        <picture>
          <source srcset="/static/img/{{ $conf.Tag }}/leading.avif" type="image/avif" />
          <img src="/static/img/{{ $conf.Tag }}/leading.png" alt="{{ $conf.Desc }}"
               class="absolute inset-0 w-full h-full object-cover" />
        </picture>
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 px-4 sm:px-6 pb-4 flex items-end justify-between gap-3 text-white">
          <div class="min-w-0">
            <div class="flex items-center gap-2">
              <span class="text-xl">{{ $conf.EmojiOrDefault }}</span>
              <h2 class="text-lg sm:text-xl font-bold truncate">{{ $conf.Desc }}</h2>
            </div>
            <p class="mt-0.5 text-xs sm:text-sm opacity-90">{{ $conf.DateDesc }} · {{ $conf.Location }}</p>
          </div>
          <span class="shrink-0 text-xs opacity-80 group-hover:opacity-100 hidden sm:inline">View conf &rarr;</span>
        </div>
      </a>
      {{ if $eb.AdminRole }}
      <a href="{{ if eq $eb.AdminRole "admin" }}/{{ $conf.Tag }}/admin{{ else }}/{{ $conf.Tag }}/volcoord{{ end }}"
         class="absolute top-2 right-2 inline-flex items-center gap-1 rounded-md bg-white/90 backdrop-blur px-2.5 py-1 text-xs font-semibold text-gray-900 shadow hover:bg-white">
        <span aria-hidden="true">🧜‍♂️</span>
        {{ if eq $eb.AdminRole "admin" }}Admin{{ else }}Vol coord{{ end }}
      </a>
      {{ end }}
    </div>

    {{ if or $eb.SpeakerConf $eb.VolApp $eb.Tickets $eb.CanBuy }}
    <div class="px-4 py-5 sm:p-6">
      {{ if and $eb.SpeakerConf $conf.CanInvite }}
      <div class="flex justify-end -mt-2 mb-2">
        <a href="/dashboard/conf/{{ $conf.Tag }}/edit?hr={{ $.HMAC }}&em={{ $.Email }}"
           class="text-xs font-medium text-gray-600 hover:text-gray-900">
          Edit speaker info &rarr;
        </a>
      </div>
      {{ end }}

      {{/* ---- Talks ---- */}}
      {{ if $eb.SpeakerConf }}
      <div class="mt-5">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-3">Talks</h3>
        <div class="space-y-3">
          {{ range $eb.SpeakerConf.Proposals }}
          <article class="flex items-stretch gap-3 rounded-md border border-gray-100 bg-gray-50/50 p-3">
            {{ if and .ConfTalk .ConfTalk.Clipart }}
            <div class="shrink-0">
              <picture>
                <source srcset="/static/img/talks/{{ .ConfTalk.ClipartAvif }}" type="image/avif" />
                <img src="/static/img/talks/{{ .ConfTalk.Clipart }}" alt=""
                     class="size-16 rounded-md object-cover bg-gray-100 ring-1 ring-gray-200" />
              </picture>
            </div>
            {{ end }}

            <div class="min-w-0 flex-1 flex flex-col">
              <div class="flex items-start justify-between gap-2">
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-gray-900 truncate">{{ .Title }}</p>
                  <p class="mt-0.5 text-xs text-gray-500">
                    {{ if .TalkType }}{{ .TalkType }}{{ end }}
                    {{ if .DesiredDuration }} &middot; {{ .DesiredDuration }} min{{ end }}
                  </p>
                </div>
                <div class="flex flex-col items-end gap-2 shrink-0">
                  <div class="flex items-center gap-2">
                    {{ if and .Recording .Recording.YTLink }}
                    <a href="{{ .Recording.YTLink }}" target="_blank" rel="noopener noreferrer"
                       title="Watch recording"
                       class="inline-flex items-center justify-center size-7 rounded-full bg-red-600 text-white hover:bg-red-700">
                      <svg viewBox="0 0 24 24" fill="currentColor" class="size-4"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    </a>
                    {{ end }}
                    {{ if eq .Status "Applied" }}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Applied</span>
                    {{ else if eq .Status "InReview" }}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">In review</span>
                    {{ else if eq .Status "Waitlisted" }}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Waitlisted</span>
                    {{ else if eq .Status "Invited" }}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">Invited</span>
                    {{ else if eq .Status "Accepted" }}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Accepted</span>
                    {{ else if eq .Status "TheyDecline" }}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Declined</span>
                    {{ else if or (eq .Status "WeDecline") (eq .Status "Rejected") }}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Not selected</span>
                    {{ else }}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">{{ .Status }}</span>
                    {{ end }}
                  </div>
                  {{ if not (or (eq .Status "Accepted") (eq .Status "TheyDecline") (eq .Status "WeDecline") (eq .Status "Rejected")) }}
                  <form method="POST" action="/dashboard/talks/{{ .ID }}/withdraw?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline">
                    <button type="submit"
                            class="inline-flex items-center px-2.5 py-1 border border-transparent text-xs font-medium rounded text-red-700 bg-red-100 hover:bg-red-200"
                            onclick="return confirm('Withdraw this talk? {{ if eq .TalkType "panel" }}You''ll be removed from the panel; the talk continues with the other speakers.{{ else }}This will withdraw the whole talk.{{ end }}');">
                      Withdraw Proposal
                    </button>
                  </form>
                  {{ end }}
                </div>
              </div>

              {{ if .Speakers }}
              {{ $proposal := . }}
              {{ $canEditSpeakers := and (and $conf $conf.CanInvite) (not (or (eq .Status "TheyDecline") (eq .Status "WeDecline") (eq .Status "Rejected"))) }}
              {{ $multi := gt (len .Speakers) 1 }}
              <div class="mt-2 flex flex-wrap items-center gap-1.5">
                {{ range .Speakers }}
                {{ if .Speaker }}
                <span class="inline-flex items-center gap-1.5 rounded-full bg-white border border-gray-200 pl-1 pr-2 py-0.5 text-xs text-gray-700">
                  <img src="{{ if .Speaker.Photo }}{{ speakerPhoto .Speaker.Photo }}{{ else }}/static/img/speaker-placeholder.png{{ end }}"
                       alt="{{ .Speaker.Name }}"
                       class="size-5 rounded-full object-cover bg-gray-100" />
                  <span class="truncate max-w-[10rem]">{{ .Speaker.Name }}</span>
                  {{ if and $canEditSpeakers (and $multi (ne .ID $eb.SpeakerConf.ID)) }}
                  <form method="POST" action="/dashboard/talks/{{ $proposal.ID }}/speakers/{{ .ID }}/remove?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline-flex">
                    <button type="submit"
                            title="Remove {{ .Speaker.Name }} from this talk"
                            onclick="return confirm('Remove {{ .Speaker.Name }} from this talk?');"
                            class="ml-0.5 inline-flex items-center justify-center size-4 rounded-full text-gray-400 hover:text-red-700 hover:bg-red-100 leading-none">
                      &times;
                    </button>
                  </form>
                  {{ end }}
                </span>
                {{ end }}
                {{ end }}
              </div>
              {{ end }}

              <div class="mt-2 flex flex-wrap items-center gap-3">
                {{ if or (eq .Status "TheyDecline") (eq .Status "WeDecline") (eq .Status "Rejected") }}
                <a href="/dashboard/talks/{{ .ID }}/details?hr={{ $.HMAC }}&em={{ $.Email }}"
                   class="inline-flex items-center text-xs font-medium text-gray-600 hover:text-gray-900">
                  Talk details &rarr;
                </a>
                {{ else }}
                <a href="/dashboard/talks/{{ .ID }}/edit?hr={{ $.HMAC }}&em={{ $.Email }}"
                   class="inline-flex items-center text-xs font-medium text-gray-600 hover:text-gray-900">
                  Edit talk &rarr;
                </a>
                {{ end }}
                {{ if and (and $conf $conf.CanInvite) (not (or (eq .Status "TheyDecline") (eq .Status "WeDecline") (eq .Status "Rejected"))) }}
                <a href="/dashboard/invite/{{ .ID }}?hr={{ $.HMAC }}&em={{ $.Email }}"
                   class="inline-flex items-center text-xs font-medium text-indigo-600 hover:text-indigo-700">
                  Invite a co-speaker &rarr;
                </a>
                {{ end }}
                {{ if eq .Status "Invited" }}
                <form method="POST" action="/dashboard/talks/{{ .ID }}/accept?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline">
                  <button type="submit"
                          class="inline-flex items-center px-2.5 py-1 border border-transparent text-xs font-medium rounded text-white bg-green-600 hover:bg-green-700"
                          onclick="return confirm('Accept this invitation? Your talk will be added to the program and you''ll be on the public agenda.');">
                    Accept invitation
                  </button>
                </form>
                {{ end }}
              </div>
            </div>
          </article>
          {{ end }}
        </div>
        {{ if $conf.TalksOpen }}
        <div class="mt-3 text-right">
          <a href="/talk/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
             class="inline-flex items-center text-xs font-medium text-indigo-600 hover:text-indigo-700">
            + Propose another talk
          </a>
        </div>
        {{ end }}
      </div>
      {{ else if $conf.TalksOpen }}
      <div class="mt-5">
        <a href="/talk/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
           class="inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-700">
          + Propose a talk for {{ $conf.Desc }}
        </a>
      </div>
      {{ end }}

      {{/* ---- Volunteer ---- */}}
      {{ if $eb.VolApp }}
      {{ $vol := $eb.VolApp }}
      <div class="mt-5">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500">Volunteer</h3>
          {{ if eq $vol.Status "Waitlist" }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Waitlist</span>
          {{ else if eq $vol.Status "Accepted" }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Accepted</span>
          {{ else if eq $vol.Status "PendingShifts" }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Select shifts</span>
          {{ else if eq $vol.Status "Scheduled" }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Scheduled</span>
          {{ else if eq $vol.Status "Declined" }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Declined</span>
          {{ else }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">{{ $vol.Status }}</span>
          {{ end }}
        </div>

        {{ if and (eq $vol.Status "Scheduled") $eb.VolInfo }}
        {{ $vinfo := $eb.VolInfo }}
        <div class="rounded-lg bg-indigo-50 border border-indigo-200 px-4 py-4 mb-3">
          <div class="flex items-start justify-between">
            <div>
              <h4 class="text-sm font-semibold text-indigo-900">Volunteer Orientation</h4>
              {{ if $vinfo.OrientTimes }}
              <p class="mt-1 text-sm text-indigo-800">{{ $vinfo.OrientTimes.FmtRange }}</p>
              {{ else }}
              <p class="mt-1 text-sm text-indigo-700">Time TBD - check back soon!</p>
              {{ end }}
              {{ if $vinfo.Notes }}
              <p class="mt-1 text-xs text-indigo-700">{{ $vinfo.Notes }}</p>
              {{ end }}
            </div>
            {{ if $vinfo.OrientLink }}
            <a href="{{ $vinfo.OrientLink }}" target="_blank" rel="noopener noreferrer"
               class="ml-4 shrink-0 inline-flex items-center px-3 py-2 border border-transparent text-xs font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700">
              Join Orientation
            </a>
            {{ end }}
          </div>
        </div>
        {{ end }}

        {{ if and $vol.WorkShifts (ne $vol.Status "Declined") }}
        <div class="overflow-hidden rounded-lg border border-gray-200 mb-3">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Day</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Time</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Shift</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              {{ range $vol.WorkShifts }}
              <tr>
                <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-900">{{ .DayOfDesc }}</td>
                <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-500">{{ .TimeDesc }}</td>
                <td class="px-4 py-2 text-sm text-gray-900">
                  {{ .Name }}
                  {{ if .Type }}
                  <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">{{ .Type.Title }}</span>
                  {{ end }}
                </td>
              </tr>
              {{ end }}
            </tbody>
          </table>
        </div>
        {{ end }}

        <div class="flex flex-wrap items-center gap-3">
          {{ if eq $vol.Status "PendingShifts" }}
          <a href="/vols/shift/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
             class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">Select your shifts</a>
          {{ else if eq $vol.Status "Scheduled" }}
          <a href="/vols/shift/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
             class="inline-flex items-center px-3 py-1.5 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50">View/edit shifts</a>
          <a href="/ticket/{{ $vol.TicketRef }}/pdf?type=volunteer&conf={{ $conf.Ref }}"
             class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded text-orange-700 bg-orange-100 hover:bg-orange-200">Download volunteer ticket</a>
          {{ else if eq $vol.Status "Applied" }}
          <p class="text-sm text-gray-600">Your application has been received! Shift selection will open soon.</p>
          {{ else if eq $vol.Status "Waitlist" }}
          <p class="text-sm text-gray-600">We're currently out of available shifts. We'll email you if a spot opens up.</p>
          {{ else if eq $vol.Status "Declined" }}
          <p class="text-sm text-gray-600">You've let us know you can't attend. Thanks for letting us know!</p>
          {{ else }}
          <a href="/vols/shift/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
             class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50">Sign up for shifts</a>
          {{ end }}

          {{ if ne $vol.Status "Declined" }}
          <form method="POST" action="/vols/shift/{{ $conf.Tag }}/decline?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline">
            <button type="submit"
                    class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded text-red-700 bg-red-100 hover:bg-red-200"
                    onclick="return confirm('Let us know you can no longer attend? This will release any shifts you signed up for.')">Can't attend</button>
          </form>
          {{ end }}
        </div>
        {{ if and (eq $vol.Status "Scheduled") $conf.WithinTwoWeeks }}
        <p class="mt-2 text-xs text-gray-500">You're scheduled and we're within two weeks of the conference. If you can no longer attend, please reach out: <a href="mailto:volunteer@btcpp.dev" class="text-indigo-600 hover:text-indigo-500">volunteer@btcpp.dev</a>.</p>
        {{ end }}
      </div>
      {{ end }}

      {{/* ---- Tickets ---- */}}
      {{ if $eb.Tickets }}
      <div class="mt-5">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-3">Tickets</h3>
        <ul class="space-y-2">
          {{ range $eb.Tickets }}
          <li class="flex items-center justify-between gap-3 rounded-md bg-gray-50/50 border border-gray-100 px-3 py-2">
            <div class="min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate">{{ if .Type }}{{ .Type }} ticket{{ else }}Ticket{{ end }}</p>
            </div>
            <a href="/ticket/{{ .RefID }}/pdf?type={{ .Type }}&conf={{ .ConfRef }}"
               class="shrink-0 inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md text-orange-700 bg-orange-100 hover:bg-orange-200">
              Download
            </a>
          </li>
          {{ end }}
        </ul>
      </div>
      {{ end }}

      {{/* ---- Buy more / get a ticket CTA ---- */}}
      {{ if $eb.CanBuy }}
      <div class="mt-5">
        <a href="/conf/{{ $conf.Tag }}#tickets"
